<launch>
  <!-- Required: IP address of the mote robot -->
  <arg name="robot_ip" />

  <!-- Wheel geometry — must match controllers.yaml if overriding -->
  <arg name="wheel_separation" default="0.15" />
  <arg name="wheel_radius"     default="0.033" />

  <!-- TF frame IDs -->
  <arg name="laser_frame" default="laser" />
  <arg name="imu_frame"   default="imu_link" />

  <!-- Sensor positions relative to base_link (meters / radians).
       Adjust these to match your robot's physical layout. -->
  <arg name="laser_x"   default="0.0" />
  <arg name="laser_y"   default="0.0" />
  <arg name="laser_z"   default="0.1" />
  <arg name="laser_yaw" default="0.0" />
  <arg name="imu_x"     default="0.0" />
  <arg name="imu_y"     default="0.0" />
  <arg name="imu_z"     default="0.0" />

  <!-- Load controller configuration -->
  <rosparam file="$(find mote_base)/config/controllers.yaml" command="load" />

  <!-- Apply wheel geometry overrides on top of the YAML defaults -->
  <param name="diff_drive_controller/wheel_separation" value="$(arg wheel_separation)" />
  <param name="diff_drive_controller/wheel_radius"     value="$(arg wheel_radius)" />

  <!-- Hardware interface node -->
  <node pkg="mote_base" type="mote_node" name="mote_node" output="screen">
    <param name="robot_ip"    value="$(arg robot_ip)" />
    <param name="laser_frame" value="$(arg laser_frame)" />
    <param name="imu_frame"   value="$(arg imu_frame)" />
  </node>

  <!-- Spawn the diff_drive_controller via controller_manager -->
  <node pkg="controller_manager" type="spawner" name="controller_spawner"
        args="diff_drive_controller" output="screen" />

  <!-- Static transforms: sensor frames relative to base_link -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="laser_tf"
        args="$(arg laser_x) $(arg laser_y) $(arg laser_z) $(arg laser_yaw) 0 0 base_link $(arg laser_frame)" />
  <node pkg="tf2_ros" type="static_transform_publisher" name="imu_tf"
        args="$(arg imu_x) $(arg imu_y) $(arg imu_z) 0 0 0 base_link $(arg imu_frame)" />

  <!-- Foxglove Bridge — connect Foxglove Studio to ws://<host>:8765 -->
  <node pkg="foxglove_bridge" type="foxglove_bridge" name="foxglove_bridge" output="screen" />
</launch>
